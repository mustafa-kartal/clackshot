{
  "name": "clackshot",
  "version": "0.1.0",
  "description": "Modern cross-platform screenshot and screen recording tool",
  "main": "dist-electron/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build:preload": "node scripts/build-preload.mjs",
    "build": "npm run build:preload && vite build && electron-builder",
    "build:mac": "npm run build:preload && vite build && electron-builder --mac",
    "build:win": "npm run build:preload && vite build && electron-builder --win",
    "build:linux": "npm run build:preload && vite build && electron-builder --linux",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "electron-store": "^10.0.0",
    "electron-updater": "^6.8.3",
    "konva": "^9.3.16",
    "mp4-muxer": "^5.2.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-konva": "^18.2.10",
    "sharp": "^0.33.5",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.8.1",
    "@typescript-eslint/parser": "^8.8.1",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.7",
    "esbuild": "^0.21.5",
    "eslint": "^9.12.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "extends": "./electron-builder.yml"
  }
}
